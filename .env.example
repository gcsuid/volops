# VolOps – Environment Variables
# Copy this file to .env and fill in your values.

PORT=3000

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Paste your MongoDB connection string here
# Example: mongodb://localhost:27017/volops
# Example Atlas: mongodb+srv://username:password@cluster.mongodb.net/volops
MONGODB_URI=

# ─── Optional: Base URL for QR codes ──────────────────────────────────────────
BASE_URL=http://localhost:3000
