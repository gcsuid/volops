# VolOps – Environment Variables
# Copy this file to .env and fill in values as needed.

# Server port (optional, defaults to 3000)
PORT=3000

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# When you are ready to connect MongoDB, paste your connection string here.
# Install the driver first:  npm install mongodb   (or mongoose)
# Then integrate it in server.js where MONGODB_URL is read.
MONGODB_URL=
